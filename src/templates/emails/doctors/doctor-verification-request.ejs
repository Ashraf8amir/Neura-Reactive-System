<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Doctor Verification Request</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 750px;
      margin: 0 auto;
      padding: 20px;
      background-color: #eef2f7;
    }

    .container {
      background-color: #fff;
      border-radius: 12px;
      padding: 40px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
      overflow: hidden;
    }

    .header {
      background: linear-gradient(135deg, #5a67d8 0%, #805ad5 100%);
      color: white;
      padding: 35px;
      border-radius: 12px 12px 0 0;
      margin: -40px -40px 30px -40px;
      text-align: center;
    }

    .header h1 {
      margin: 0;
      font-size: 28px;
    }

    .badge {
      display: inline-block;
      background-color: #ffd700;
      color: #333;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: bold;
      margin-top: 10px;
    }

    .alert-box {
      background-color: #fff9e6;
      border-left: 5px solid #f6c343;
      padding: 15px;
      margin: 20px 0;
      border-radius: 5px;
      font-size: 15px;
    }

    .timestamp {
      background-color: #ebf4ff;
      color: #2c5282;
      padding: 10px;
      border-radius: 6px;
      text-align: center;
      margin: 20px 0;
      font-size: 14px;
      font-weight: 500;
    }

    .info-section {
      background-color: #f8faff;
      border-left: 4px solid #5a67d8;
      padding: 20px;
      margin: 25px 0;
      border-radius: 8px;
    }

    .info-row {
      display: flex;
      margin-bottom: 12px;
    }

    .info-label {
      font-weight: 600;
      color: #4c51bf;
      min-width: 180px;
    }

    .info-value {
      color: #555;
    }

    .documents-section {
      margin: 35px 0;
    }

    .documents-section h2 {
      color: #4c51bf;
      border-bottom: 3px solid #5a67d8;
      padding-bottom: 10px;
      margin-bottom: 20px;
    }

    .document-item {
      background-color: #fafbff;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 15px;
      margin-bottom: 20px;
    }

    .document-name {
      font-weight: 600;
      color: #333;
      margin-bottom: 10px;
    }

    .document-preview {
      width: 100%;
      border-radius: 8px;
      border: 1px solid #d0d7e2;
      transition: transform 0.2s ease;
    }

    .document-preview:hover {
      transform: scale(1.02);
    }

    .footer {
      text-align: center;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e0e0e0;
      color: #777;
      font-size: 13px;
    }

    .action-box {
      background-color: #edf2ff;
      padding: 20px;
      border-radius: 8px;
      text-align: center;
      margin-top: 30px;
    }

    .action-box p {
      margin: 0;
      color: #444;
    }

    .action-box strong {
      color: #2f855a;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>🩺 New Doctor Verification Request</h1>
      <span class="badge">⏳ PENDING REVIEW</span>
    </div>

    <div class="alert-box">
      <strong>⚠️ Action Required:</strong> A new doctor has submitted their verification documents and is awaiting your review.
    </div>

    <div class="timestamp">
      📅 Submitted on: <strong><%= submittedAt %></strong>
    </div>

    <div class="info-section">
      <h3 style="margin-top: 0; color: #4c51bf;">👨‍⚕️ Doctor Information</h3>
      <div class="info-row">
        <span class="info-label">Full Name:</span>
        <span class="info-value"><%= doctorName %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Email:</span>
        <span class="info-value"><%= doctorEmail %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Doctor ID:</span>
        <span class="info-value"><%= doctorId %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Specialization:</span>
        <span class="info-value"><%= primarySpecialization %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Years of Experience:</span>
        <span class="info-value"><%= yearsOfExperience %> years</span>
      </div>
    </div>

    <div class="documents-section">
      <h2>📋 Submitted Documents</h2>

      <div class="document-item">
        <div class="document-name">🪪 National ID (Front)</div>
        <img src="<%= documents.nationalIdFront %>" alt="National ID Front" class="document-preview" />
      </div>

      <div class="document-item">
        <div class="document-name">🪪 National ID (Back)</div>
        <img src="<%= documents.nationalIdBack %>" alt="National ID Back" class="document-preview" />
      </div>

      <div class="document-item">
        <div class="document-name">🎓 Medical Degree Certificate</div>
        <img src="<%= documents.medicalDegreeCertificate %>" alt="Medical Degree Certificate" class="document-preview" />
      </div>

      <div class="document-item">
        <div class="document-name">🏥 Syndicate Membership Card</div>
        <img src="<%= documents.syndicateMembershipCard %>" alt="Syndicate Membership Card" class="document-preview" />
      </div>

      <div class="document-item">
        <div class="document-name">📜 Medical License</div>
        <img src="<%= documents.medicalLicense %>" alt="Medical License" class="document-preview" />
      </div>
    </div>

    <div class="action-box">
      <p>Please review the documents and take action:</p>
      <p>
        Log in to the admin dashboard to
        <strong style="color: #38a169;">approve</strong> or
        <strong style="color: #e53e3e;">reject</strong> this verification request.
      </p>
    </div>

    <div class="footer">
      <p>This is an automated notification from Maweed Medical System</p>
      <p>© <%= new Date().getFullYear() %> Maweed. All rights reserved.</p>
    </div>
  </div>
</body>
</html>